{
  "info": {
    "name": "KSB .NET API",
    "description": "Single collection for .NET auth, roles, users, and master-data APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:5088/api"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin@example.com\",\n  \"password\": \"password\",\n  \"unique_id\": \"postman-device\",\n  \"device_type\": \"web\",\n  \"device_name\": \"Postman\",\n  \"app_version\": \"1.0.0\"\n}"
            },
            "url": "{{base_url}}/login"
          }
        },
        {
          "name": "Signup User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Test\",\n  \"last_name\": \"User\",\n  \"name\": \"Test User\",\n  \"mobile\": \"9999999999\",\n  \"email\": \"test.user@example.com\",\n  \"password\": \"password\",\n  \"roles\": [2],\n  \"cities\": [],\n  \"branch_id\": [1],\n  \"show_attandance_report\": \"1\"\n}"
            },
            "url": "{{base_url}}/signup"
          }
        },
        {
          "name": "Customer Signup",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Customer\",\n  \"shop_name\": \"Customer Shop\",\n  \"mobile\": \"9999999999\",\n  \"email\": \"customer@example.com\",\n  \"password\": \"password\",\n  \"device_type\": \"web\",\n  \"device_name\": \"Postman\",\n  \"app_version\": \"1.0.0\"\n}"
            },
            "url": "{{base_url}}/customerSignup"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/logout"
          }
        }
      ]
    },
    {
      "name": "Roles",
      "item": [
        {
          "name": "List Roles",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/roles?include_permissions=true"
          }
        },
        {
          "name": "Get Role",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/roles/1"
          }
        },
        {
          "name": "Create Role",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Role\",\n  \"guard_name\": \"users\",\n  \"permissions\": [1, 2]\n}"
            },
            "url": "{{base_url}}/roles"
          }
        },
        {
          "name": "Update Role",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Role\",\n  \"guard_name\": \"users\",\n  \"permissions\": [1, 2, 3]\n}"
            },
            "url": "{{base_url}}/roles/1"
          }
        },
        {
          "name": "Delete Role",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/roles/1"
          }
        },
        {
          "name": "Sync Role Permissions",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"permissions\": [1, 2, 3]\n}"
            },
            "url": "{{base_url}}/roles/1/permissions"
          }
        },
        {
          "name": "Save Role Permissions",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"permissions\": {\n    \"1\": [1, 2, 3]\n  }\n}"
            },
            "url": "{{base_url}}/roles/save-permissions"
          }
        },
        {
          "name": "List Permissions",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/permissions"
          }
        }
      ]
    },
